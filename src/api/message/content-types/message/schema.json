{
  "kind": "collectionType",
  "collectionName": "messages",
  "info": {
    "singularName": "message",
    "pluralName": "messages",
    "displayName": "Message"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "role": {
      "type": "enumeration",
      "enum": [
        "user",
        "character"
      ]
    },
    "content": {
      "type": "text"
    },
    "message_type": {
      "type": "enumeration",
      "enum": [
        "question",
        "info_request",
        "answer"
      ]
    },
    "chat_thread": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::chat-thread.chat-thread",
      "inversedBy": "messages"
    },
    "character": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::character.character",
      "inversedBy": "messages"
    }
  }
}
