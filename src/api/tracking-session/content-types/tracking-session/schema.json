{
  "kind": "collectionType",
  "collectionName": "tracking_sessions",
  "info": {
    "singularName": "tracking-session",
    "pluralName": "tracking-sessions",
    "displayName": "tracking-sessions"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string"
    },
    "notes": {
      "type": "text"
    },
    "session_id": {
      "type": "string"
    },
    "decoy_url": {
      "type": "string"
    },
    "tracking_link": {
      "type": "string"
    },
    "investigator_name": {
      "type": "string"
    },
    "status1": {
      "type": "enumeration",
      "enum": [
        "active",
        "triggered",
        "expired"
      ]
    },
    "tracking_events": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::tracking-event.tracking-event",
      "mappedBy": "session"
    }
  }
}
