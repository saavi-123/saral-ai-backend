      "mappedBy": "project"
    },
    "context_items": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::context-item.context-item",
      "mappedBy": "project"
    },
    "chat_threads": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::chat-thread.chat-thread",
      "mappedBy": "project"
    },
    "project_id": {
      "type": "string"
    }
